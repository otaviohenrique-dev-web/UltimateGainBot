# ==========================================
# 1. SEGURANÇA E CHAVES (CRÍTICO)
# ==========================================
# Ignora todos os arquivos de ambiente que contenham senhas reais
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# EXCEÇÃO: Permite que o arquivo de exemplo suba para o GitHub
!.env.example

# ==========================================
# 2. BACKEND (Python / FastAPI)
# ==========================================
# Pastas de ambiente virtual (pesam centenas de megabytes e variam por PC)
venv/
.venv/
env/

# Arquivos compilados do Python (lixo gerado ao rodar o script)
__pycache__/
*.py[cod]
*$py.class

# Cache de testes do pytest que rodamos na Fase 4
.pytest_cache/
.coverage

# ==========================================
# 3. FRONTEND (Node.js / Next.js)
# ==========================================
# A pasta mais pesada do universo. O Vercel vai baixar tudo sozinho lá na nuvem.
node_modules/

# Pasta de build compilada do Next.js (gerada automaticamente)
.next/
out/
build/

# Logs de erro de pacotes
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 4. SISTEMA OPERACIONAL E EDITORES DE CÓDIGO
# ==========================================
# Arquivos de thumbnail e indexação do Windows e Mac
Thumbs.db
.DS_Store

# Configurações pessoais da sua IDE (VS Code, PyCharm, etc)
.vscode/
.idea/
